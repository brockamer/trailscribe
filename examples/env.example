# Example environment file for TrailScribe

# API keys and tokens
OPENAI_API_KEY=
TODOIST_API_TOKEN=
POSTHAVEN_TO=

# Garmin and mapping
GOOGLE_MAPS_BASE=https://www.google.com/maps/search/?api=1&query=
MAPSHARE_BASE=https://share.garmin.com/your_mapshare_id

# Email
GMAIL_SENDER=youremail@gmail.com

# Cost tracking
DAILY_TOKEN_BUDGET=0
APPEND_COST_SUFFIX=true
OPENAI_INPUT_COST_PER_1K=0.00
OPENAI_OUTPUT_COST_PER_1K=0.00
LEDGER_BACKEND=memory